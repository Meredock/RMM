# Copy to .env (next to docker-compose.yml) and fill in. Generate secrets with:
#   openssl rand -base64 32

# Domain that points (DNS A record) at this server; Caddy gets HTTPS for it.
DASHBOARD_DOMAIN=dashboard.example.com

# PostgreSQL password (used by both db and dashboard)
POSTGRES_PASSWORD=change-me

# Dashboard secrets
JWT_SECRET=change-me-random
DASHBOARD_PASSWORD=change-me-login-password
AGENT_REGISTRATION_SECRET=change-me-random

# --- Optional ---
# Only set COOKIE_DOMAIN if you serve the app across subdomains (e.g. ".example.com")
COOKIE_DOMAIN=
# Vault encryption key: base64 32 bytes (openssl rand -base64 32). If unset, a
# key is derived from JWT_SECRET. IMPORTANT: keep this stable — changing it makes
# existing stored secrets undecryptable.
VAULT_KEY=
# Outbound notifications (Slack/Discord/custom incoming webhook)
ALERT_WEBHOOK_URL=
# S3 backups (presigning happens server-side; agents never see these)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
# Agent auto-update (point at a reachable rmm-agent.exe, e.g. a GitHub release)
AGENT_LATEST_VERSION=
AGENT_DOWNLOAD_URL_WINDOWS=

# --- Tickets app (only if you run docker-compose.tickets.yml) ---
# Tickets reuses JWT_SECRET above for shared login with the dashboard.
TICKETS_DB_PASSWORD=change-me
TICKETS_DB_ROOT=change-me-root
# SMTP for ticket emails (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Host ports (override only if these are taken on a shared server) ---
# Josh runs Gitea on 3009; these defaults (3000 / 8090) avoid it.
DASHBOARD_HOST_PORT=3000
TICKETS_HOST_PORT=8090
