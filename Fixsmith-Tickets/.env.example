# MySQL connection string — from cPanel Database Wizard
DATABASE_URL=mysql://user:password@localhost:3306/dbname

# Must match the JWT_SECRET used by the RMM Dashboard (Render env var)
JWT_SECRET=your-jwt-secret-here

# Port — cPanel Node.js sets this automatically via the PORT env var
PORT=3000

# SMTP — for sending emails directly from tickets
SMTP_HOST=mail.fixsmith.com.au
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@fixsmith.com.au
SMTP_PASS=your-smtp-password
SMTP_FROM=Fixsmith Tickets <noreply@fixsmith.com.au>
