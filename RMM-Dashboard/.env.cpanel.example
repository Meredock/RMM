# PostgreSQL connection string for the database reachable from cPanel.
# Prefer a PostgreSQL database on the host/VPS or a managed external PostgreSQL instance.
DATABASE_URL="postgresql://user:password@host:5432/rmm_dashboard"

# Required for login session cookies. Use a long random value.
JWT_SECRET="replace-with-a-long-random-secret"

# Dashboard login password.
DASHBOARD_PASSWORD="replace-with-a-strong-password"

# Secret agents must provide when registering.
AGENT_REGISTRATION_SECRET="replace-with-a-long-random-secret"

# cPanel usually injects PORT automatically. Only set these manually if your host asks for them.
NODE_ENV="production"
HOST="0.0.0.0"
# PORT="3000"
