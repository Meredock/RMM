# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/rmm_dashboard"

# Secret used to sign session JWTs (generate with: openssl rand -base64 32)
JWT_SECRET="change-me-to-a-random-secret"

# Dashboard login password
DASHBOARD_PASSWORD="admin"

# API key used when registering new devices (keep secret)
AGENT_REGISTRATION_SECRET="change-me-to-a-random-secret"
