# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/rmm_dashboard"

# Secret used to sign session JWTs (generate with: openssl rand -base64 32)
JWT_SECRET="change-me-to-a-random-secret"

# Dashboard login password
DASHBOARD_PASSWORD="admin"

# API key used when registering new devices (keep secret)
AGENT_REGISTRATION_SECRET="change-me-to-a-random-secret"

# --- S3 backup storage (optional) ---
# Required only when a backup job uses S3 storage. The dashboard uses these to
# presign short-lived upload URLs; credentials never reach the agents.
# Works with AWS S3 and S3-compatible providers (Backblaze B2, Cloudflare R2,
# Wasabi, MinIO) via the job's optional endpoint/region.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Optional default region if a job doesn't set one
AWS_REGION="ap-southeast-2"
# Optional, only for temporary STS credentials
# AWS_SESSION_TOKEN=""

# --- Vault encryption (optional) ---
# Base64-encoded 32-byte key for the credential vault (openssl rand -base64 32).
# If unset, a key is derived from JWT_SECRET so the vault still works.
VAULT_KEY=""
